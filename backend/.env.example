# backend/.env — copy to .env and adjust (never commit .env)
DATABASE_URL=postgresql://fantasyuser:localpassword@localhost:5432/fantasy_db
# AWS RDS — set DATABASE_URL host to this value for Lambda/production (credentials stay secret)
RDS_HOSTNAME=your-db.xxxxx.us-east-1.rds.amazonaws.com
SLEEPER_BASE_URL=https://api.sleeper.app/v1
# Comma-separated list, e.g. http://localhost:5173,https://app.example.com
CORS_ORIGINS=
NFL_SEASON=2025
# Optional: override ESPN scoreboard URL (same JSON shape) or point to your proxy
# NFL_SCOREBOARD_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/football/nfl/scoreboard
# NFL_GAME_SUMMARY_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/football/nfl/summary
AWS_REGION=us-east-1
